# Copy to `.env` in the project root. Vite exposes only variables prefixed with VITE_.
# Must match the presales backend’s host:port (whatever `app.listen` uses). No trailing slash.
# If the browser shows net::ERR_CONNECTION_REFUSED, the backend is not running or the port is wrong.
VITE_API_URL=http://localhost:6969
# Optional aliases (same semantics — backend base, no trailing slash)
# VITE_API_BASE_URL=http://localhost:6969
# NEXT_PUBLIC_API_URL=http://localhost:6969
